<%# locals: (result:, period:, **args) %>

<% if result.accounts.any? %>
  <div id="investments-pro" class="space-y-4">
    <div class="flex justify-between gap-4 px-4">
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <h2 class="text-lg font-medium"><%= t(".title") %></h2>
        </div>

        <p class="text-primary text-3xl font-medium privacy-sensitive">
          <% if result.total_arr %>
            <%= number_to_percentage(result.total_arr * 100, precision: 2) %>
          <% else %>
            <span class="text-secondary text-lg"><%= t(".not_available") %></span>
          <% end %>
        </p>

        <div class="flex items-center gap-2 text-sm">
          <span class="text-secondary"><%= t(".interest_earned") %>:</span>
          <span class="font-medium text-green-600 privacy-sensitive"><%= format_money(result.total_interest) %></span>
        </div>

        <p class="text-xs text-secondary">
          <%= result.annualized ? t(".annualized_note") : t(".short_period_note", min_days: InvestmentProStatement::MIN_ANNUALIZE_DAYS) %>
        </p>
      </div>
    </div>

    <div class="bg-container-inset rounded-xl p-1 mx-4 overflow-x-auto">
      <div class="rounded-lg shadow-border-xs bg-container overflow-hidden">
        <table class="w-full">
          <thead class="bg-container-inset">
            <tr class="uppercase text-xs font-medium text-secondary">
              <th class="px-4 py-2 text-left font-medium"><%= t(".account") %></th>
              <th class="px-4 py-2 text-right font-medium"><%= t(".interest") %></th>
              <th class="px-4 py-2 text-right font-medium"><%= t(".avg_balance") %></th>
              <th class="px-4 py-2 text-right font-medium"><%= t(".arr") %></th>
            </tr>
          </thead>
          <tbody class="font-medium text-sm">
            <% result.accounts.each_with_index do |row, idx| %>
              <tr class="<%= idx < result.accounts.size - 1 ? "table-divider" : "" %>">
                <td class="p-4">
                  <p class="font-medium truncate max-w-48"><%= row.account.name %></p>
                </td>
                <td class="p-4 text-right text-green-600 privacy-sensitive"><%= format_money(row.interest) %></td>
                <td class="p-4 text-right privacy-sensitive"><%= format_money(row.avg_balance) %></td>
                <td class="p-4 text-right">
                  <% if row.arr %>
                    <span class="privacy-sensitive"><%= number_to_percentage(row.arr * 100, precision: 2) %></span>
                  <% else %>
                    <span class="text-secondary">-</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
